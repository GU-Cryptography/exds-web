#!/bin/sh
set -e

if [ -x ".venv/Scripts/python" ]; then
  PYTHON_BIN=".venv/Scripts/python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="python3"
else
  PYTHON_BIN="python"
fi

echo "[garbled-check] using $PYTHON_BIN"
"$PYTHON_BIN" scripts/check_garbled_staged.py

echo "[auth-check] using $PYTHON_BIN"
"$PYTHON_BIN" scripts/check_auth_all.py
